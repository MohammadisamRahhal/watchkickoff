# ─────────────────────────────────────────────────────────────────
# WatchKickoff — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# All variables are validated at startup via config/env.ts.
# Missing or invalid variables cause immediate process.exit(1).
# ─────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────
# Application environment. Controls optimisations, debug routes, log format.
NODE_ENV=development

# Fastify API server port. Nginx proxies to this value.
PORT=3001

# ── Database ─────────────────────────────────────────────────────
# Full PostgreSQL connection string. Include pool params in query string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=...
DATABASE_URL=postgresql://watchkickoff:changeme@localhost:5432/watchkickoff

# PostgreSQL connection pool — minimum idle connections.
DB_POOL_MIN=2

# PostgreSQL connection pool — maximum connections.
# Do not exceed (max_connections - 10) from postgresql.conf.
DB_POOL_MAX=20

# ── Redis ────────────────────────────────────────────────────────
# ioredis connection string. Same instance used for cache, pub/sub, and BullMQ.
REDIS_URL=redis://localhost:6379

# ── Data Provider ────────────────────────────────────────────────
# API-Football secret key. Injected here, read only in infrastructure/http/.
# ROTATE IMMEDIATELY if ever exposed in plain text.
FOOTBALL_API_KEY=your_api_football_key_here

# API-Football base URL. Change to a mock server URL in tests.
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io

# Hard daily call cap — enforced by token bucket in rate-limiter.ts.
# Set to 93% of your plan's daily limit to preserve a safety buffer.
# PRO plan = 7500 calls/day → cap at 7000.
FOOTBALL_API_DAILY_LIMIT=7000

# Per-minute call cap — API-Football also enforces a per-minute rate limit.
FOOTBALL_API_PER_MINUTE_LIMIT=30

# ── CORS ─────────────────────────────────────────────────────────
# Allowed CORS origin. Single value — no wildcard in production.
# No trailing slash.
CORS_ORIGIN=https://watchkickoff.com

# ── Logging ──────────────────────────────────────────────────────
# Pino log level. Use 'info' in production, 'debug' in development.
# Valid values: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Background Sync ──────────────────────────────────────────────
# Live match poll interval in milliseconds.
# 15000 = 15 seconds (aligned to API-Football update cadence).
SYNC_INTERVAL_LIVE_MS=15000

# Fixture sync — cron expression (every 6 hours).
SYNC_INTERVAL_FIXTURE_CRON=0 */6 * * *

# Standings sync — nightly safety net cron expression.
SYNC_INTERVAL_STANDING_CRON=0 4 * * *

# ── Rate Limiting (HTTP API) ─────────────────────────────────────
# Max requests per IP per window. Applied via fastify-rate-limit.
RATE_LIMIT_MAX=100

# Rate limit window in milliseconds (default: 60 seconds).
RATE_LIMIT_WINDOW_MS=60000

# ── Internal Services ────────────────────────────────────────────
# HTTP header name used to propagate correlation IDs across services.
CORRELATION_ID_HEADER=x-correlation-id

# ── Bull Board (Queue Dashboard) ─────────────────────────────────
# Set to 'true' only in development or via SSH tunnel in production.
# Never expose publicly in production.
BULL_BOARD_ENABLED=false

# Basic auth password for bull-board. Required when BULL_BOARD_ENABLED=true.
BULL_BOARD_PASSWORD=changeme

# ── Next.js ISR Revalidation ─────────────────────────────────────
# Secret token sent by revalidation worker to trigger Next.js on-demand ISR.
# Must match REVALIDATION_TOKEN in apps/web/.env.
NEXT_REVALIDATION_TOKEN=changeme

# Internal URL of the Next.js process. Used by revalidation worker only.
NEXT_URL=http://localhost:3000
