# ─────────────────────────────────────────────────────────────────────────────
# WatchKickoff API — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# All variables are validated at startup — the process exits immediately
# with a descriptive error if any required variable is missing or invalid.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
# Port Fastify listens on — Nginx proxies to this port
PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string including database name
DATABASE_URL=postgresql://watchkickoff:password@127.0.0.1:5432/watchkickoff
# Connection pool sizes
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── Redis ────────────────────────────────────────────────────────────────────
# Full URL for ioredis cache and pub/sub clients
REDIS_URL=redis://127.0.0.1:6379
# Host + port used by BullMQ (plain connection options — must match REDIS_URL)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Data Provider ────────────────────────────────────────────────────────────
# API-Football PRO key — obtain from api-football.com dashboard
# ROTATE IMMEDIATELY if ever exposed in version control or logs
FOOTBALL_API_KEY=your-api-key-here
# Provider base URL — change to a mock server URL in development/testing
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
# Hard cap at 93% of PRO plan daily quota (7500 * 0.93 = 6975 — rounded to 7000)
FOOTBALL_API_DAILY_LIMIT=7000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Exact allowed origin — no trailing slash, no wildcard in production
# Development: http://localhost:3000
# Production:  https://watchkickoff.com
CORS_ORIGIN=http://localhost:3000

# ── Logging ──────────────────────────────────────────────────────────────────
# error | warn | info | debug  (use 'debug' in development, 'info' in production)
LOG_LEVEL=debug

# ── Sync Intervals ───────────────────────────────────────────────────────────
# Live match poll interval in milliseconds (15000 = 15 seconds)
SYNC_INTERVAL_LIVE_MS=15000
# Cron expression for fixture sync (default: every 6 hours)
SYNC_INTERVAL_FIXTURE_CRON=0 */6 * * *
# Cron expression for nightly standings safety-net sync
SYNC_INTERVAL_STANDING_CRON=0 4 * * *

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max HTTP requests per IP per window
RATE_LIMIT_MAX=100
# Rate limit window in milliseconds (60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# ── Database Pool ────────────────────────────────────────────────────────────
# Drizzle/pg connection pool config (already listed above)

# ── Admin / Internal ─────────────────────────────────────────────────────────
# Set to 'true' only in development — NEVER true in production
BULL_BOARD_ENABLED=false
# Password for bull-board UI (required if BULL_BOARD_ENABLED=true)
BULL_BOARD_PASSWORD=

# Secret for Next.js on-demand ISR revalidation webhook
NEXT_REVALIDATION_TOKEN=
# Internal URL of the Next.js process (for revalidation worker to call)
NEXT_URL=http://localhost:3000

# Header name used for correlation ID propagation
CORRELATION_ID_HEADER=x-correlation-id
