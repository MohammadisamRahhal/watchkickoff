{
  "name": "@watchkickoff/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc --build tsconfig.json && tsc-alias -p tsconfig.json",
    "build:force": "tsc --build --force tsconfig.json && tsc-alias -p tsconfig.json",
    "typecheck": "tsc --build --dry",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "db:migrate": "node dist/infrastructure/database/migrate.js",
    "db:generate": "drizzle-kit generate:pg"
  },
  "dependencies": {
    "@watchkickoff/shared": "*",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^8.3.1",
    "bullmq": "^5.7.4",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.27.0",
    "ioredis": "5.3.2",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-http": "^10.1.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.5",
    "@types/uuid": "^9.0.8",
    "drizzle-kit": "^0.21.1",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.9.0",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "pino-pretty": "^11.0.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5"
  }
}
