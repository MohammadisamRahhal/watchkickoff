{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@config/*":         ["config/*"],
      "@core/*":           ["core/*"],
      "@infrastructure/*": ["infrastructure/*"],
      "@modules/*":        ["modules/*"],
      "@providers/*":      ["providers/*"],
      "@jobs/*":           ["jobs/*"]
    }
  },
  "references": [
    { "path": "../../packages/shared" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
