# ── WatchKickoff Web ─────────────────────────────────────────────
# Copy to .env.local and fill in values.

# Internal URL of the Fastify API server.
# Used by Next.js server components and API route rewrites.
# In production this is the loopback address — Nginx routes /api/* externally.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Internal API URL used only by server components (not exposed to the browser).
# Can be the same as NEXT_PUBLIC_API_URL in most setups.
API_URL=http://localhost:3001

# Token that authorises on-demand ISR revalidation.
# Must match NEXT_REVALIDATION_TOKEN in the API .env.
REVALIDATION_TOKEN=changeme
